# ============================================================================
# IRAQI MARKETPLACE PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git - it contains sensitive information

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
APP_NAME=iraqi-marketplace
APP_PORT=3000
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001
MOBILE_API_URL=https://api.marketplace.iq

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=marketplace_db
DATABASE_USER=marketplace_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://marketplace_user:change_me_in_production@localhost:5432/marketplace_db

# TypeORM Configuration
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_DATABASE=marketplace_db
TYPEORM_USERNAME=marketplace_user
TYPEORM_PASSWORD=change_me_in_production
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true

# ============================================================================
# REDIS - Caching & Sessions
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ============================================================================
# ELASTICSEARCH - Search Engine
# ============================================================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ============================================================================
# JWT - JSON Web Token Configuration
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ============================================================================
# OTP SMS CONFIGURATION
# ============================================================================
# Provider: twillio | aws-sns | custom
SMS_PROVIDER=twillio
SMS_FROM_NUMBER=+964123456789

# Twillio Configuration
TWILLIO_ACCOUNT_SID=your_twillio_account_sid
TWILLIO_AUTH_TOKEN=your_twillio_auth_token
TWILLIO_PHONE_NUMBER=+1234567890

# AWS SNS Configuration (alternative to Twillio)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ============================================================================
# CLOUDFLARE R2 - Image Storage
# ============================================================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=marketplace-images
R2_PUBLIC_URL=https://images.marketplace.iq

# Image Settings
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
IMAGE_COMPRESSION_QUALITY=85
THUMBNAIL_SIZE=300x300

# ============================================================================
# FIREBASE - Push Notifications & Cloud Messaging
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key-as-json
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@marketplace.iq
MAIL_FROM_NAME=Iraqi Marketplace

# ============================================================================
# PAYMENT GATEWAY (Future Integration)
# ============================================================================
# Stripe Configuration (for future international payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Iraq Payment Gateways (to be integrated)
ZAINCASH_API_KEY=your_zaincash_api_key
ZAINCASH_API_SECRET=your_zaincash_api_secret

ASIA_HAWALA_API_KEY=your_asia_hawala_key
ASIA_HAWALA_MERCHANT_ID=your_merchant_id

QI_CARD_API_KEY=your_qi_card_api_key
QI_CARD_MERCHANT_ID=your_merchant_id

# ============================================================================
# GOOGLE MAPS (Future Integration)
# ============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================================
# ANALYTICS
# ============================================================================
# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# SECURITY
# ============================================================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=combined

# ============================================================================
# ADMIN
# ============================================================================
ADMIN_EMAIL=admin@marketplace.iq
ADMIN_PASSWORD=change_me_in_production
ADMIN_JWT_EXPIRE=24h

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_PAYMENTS=false
FEATURE_PREMIUM_ADS=false
FEATURE_AI_MODERATION=false
FEATURE_BUSINESS_ACCOUNTS=false

# ============================================================================
# DEPLOYMENT
# ============================================================================
# Use these in docker-compose.yml for containerized environment
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_TAG=latest
